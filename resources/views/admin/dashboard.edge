@component('layouts/app')
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Dashboard Admin</h1>
      <p class="mt-2 text-sm text-gray-600">Selamat datang kembali! Berikut adalah ringkasan performa hari ini.</p>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4 mb-8">
      <div class="bg-white overflow-hidden shadow-sm rounded-lg border border-gray-100">
        <div class="px-4 py-5 sm:p-6">
          <dt class="text-sm font-medium text-gray-500 truncate">Pendapatan Hari Ini</dt>
          <dd class="mt-1 text-3xl font-semibold text-indigo-600">Rp{{ stats.todayRevenue.toLocaleString('id-ID') }}</dd>
