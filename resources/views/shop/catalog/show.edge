              </div>
            </div>
          @endif

          <form action="{{ route('shop_cart.store') }}" method="POST" class="flex-1">
            {{ csrfField() }}
            <input type="hidden" name="drugId" value="{{ drug.id }}">
            <div class="flex gap-4">
              <div class="w-24">
                <label for="quantity" class="sr-only">Jumlah</label>
                <input type="number" name="quantity" id="quantity" value="1" min="1" max="100" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
              </div>
              <button type="submit" class="flex-1 bg-indigo-600 border border-transparent rounded-md py-3 px-8 flex items-center justify-center text-base font-medium text-white hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                Tambah ke Keranjang
              </button>
            </div>
          </form>
        </div>
