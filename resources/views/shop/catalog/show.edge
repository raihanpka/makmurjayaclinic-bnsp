          <div>
            <h1 class="text-3xl font-extrabold tracking-tight text-gray-900">{{ drug.name }}</h1>
            <p class="text-sm text-gray-500 mt-1">SKU: {{ drug.sku }} | Kategori: {{ drug.category.name }}</p>
          </div>
          <p class="text-3xl text-indigo-600 font-bold">Rp{{ Number(drug.price).toLocaleString('id-ID') }}</p>
        </div>

        <div class="mt-6">
          <h3 class="sr-only">Deskripsi</h3>
          <div class="text-base text-gray-700 space-y-6">
            <p>{{ drug.description || 'Tidak ada deskripsi tersedia.' }}</p>
          </div>
        </div>

        <div class="mt-8 border-t border-gray-100 pt-8">
          <div class="grid grid-cols-1 gap-y-6 sm:grid-cols-2 sm:gap-x-4">
            <div>
              <h3 class="text-sm font-medium text-gray-900">Komposisi</h3>
              <p class="mt-2 text-sm text-gray-500">{{ drug.composition || '-' }}</p>
            </div>
            <div>
              <h3 class="text-sm font-medium text-gray-900">Dosis</h3>
              <p class="mt-2 text-sm text-gray-500">{{ drug.dosage || '-' }}</p>
