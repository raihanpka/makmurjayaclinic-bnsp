      <div class="flex flex-col">
        <div class="w-full aspect-w-1 aspect-h-1 bg-gray-200 rounded-lg overflow-hidden h-96">
          @if(drug.imageUrl)
            <img src="{{ drug.imageUrl.startsWith('http') ? drug.imageUrl : '/uploads/' + drug.imageUrl }}" alt="{{ drug.name }}" class="w-full h-full object-center object-cover">
          @else
            <div class="flex items-center justify-center h-full text-gray-400">
              <i data-lucide="image-off" class="h-24 w-24"></i>
            </div>
