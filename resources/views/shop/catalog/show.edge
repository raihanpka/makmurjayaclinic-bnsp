            <div class="sm:col-span-2">
              <h3 class="text-sm font-medium text-gray-900">Efek Samping</h3>
              <p class="mt-2 text-sm text-gray-500">{{ drug.sideEffects || '-' }}</p>
            </div>
          </div>
        </div>

        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          @if(drug.requiresPrescription)
            <div class="mb-4 p-4 bg-red-50 rounded-md border border-red-200">
              <div class="flex">
                <div class="flex-shrink-0">
                  <i data-lucide="alert-triangle" class="h-5 w-5 text-red-400"></i>
