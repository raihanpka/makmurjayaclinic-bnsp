<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title || 'Makmur Jaya Pharmacy' }}</title>
  @vite(['resources/css/app.css', 'resources/js/app.js'])
</head>
<body class="bg-gray-50 text-gray-900 font-sans antialiased min-h-screen flex flex-col">
  @include('partials/header')

  <main class="flex-grow">
    @if(flashMessages.has('success') || flashMessages.has('error'))
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
        @if(flashMessages.has('success'))
          <div x-data="alert" x-cloak x-show="isVisible" class="mb-4 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded relative" role="alert">
            <span class="block sm:inline">{{ flashMessages.get('success') }}</span>
          </div>
        @endif

        @if(flashMessages.has('error'))
          <div x-data="alert" x-cloak x-show="isVisible" class="mb-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded relative" role="alert">
            <span class="block sm:inline">{{ flashMessages.get('error') }}</span>
          </div>
        @endif
      </div>
    @endif

    {{{ await $slots.main() }}}
  </main>

  <footer class="bg-white border-t border-gray-100 mt-auto">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <p class="text-center text-sm text-gray-500">&copy; {{ new Date().getFullYear() }} Klinik Makmur Jaya. Hak cipta dilindungi.</p>
    </div>
  </footer>
  <script src="https://unpkg.com/lucide@latest"></script>
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      lucide.createIcons();
    });

    function notificationsComponent() {
      return {
        open: false,
        notifications: [],
        unreadCount: 0,
        initSSE() {
          // Fetch initial notifications
          fetch('/api/notifications')
            .then(res => res.json())
            .then(data => {
              this.notifications = data;
              this.unreadCount = this.notifications.filter(n => !n.isRead).length;
            });

          // Connect to SSE
          const eventSource = new EventSource('/api/notifications/sse');
          
          eventSource.onmessage = (event) => {
            const data = JSON.parse(event.data);
            if (data.type === 'connected') return;

            // Prepend new notification
            this.notifications.unshift(data);
            if (!data.isRead) {
              this.unreadCount++;
            }
          };

          eventSource.onerror = (error) => {
            console.error('SSE Error:', error);
          };
        },
        markAsRead(id) {
          fetch(`/api/notifications/${id}/read`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': '{{ csrfToken }}' }
          });
        },
        markAllAsReadLocally() {
          this.unreadCount = 0;
          this.notifications.forEach(n => n.isRead = true);
        },
        formatDate(dateStr) {
          if (!dateStr) return '';
          return new Date(dateStr).toLocaleString('id-ID', {
            day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit'
          });
        }
      }
    }
  </script>
</body>
</html>
